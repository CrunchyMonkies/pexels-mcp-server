{
  "name": "pexels-mcp-server",
  "version": "2.0.0",
  "description": "MCP server for the Pexels API (Bun runtime, image manipulation, stdio + Streamable HTTP transports)",
  "type": "module",
  "main": "src/main.ts",
  "bin": {
    "pexels-mcp-server": "src/main.ts"
  },
  "scripts": {
    "start": "bun src/main.ts",
    "dev": "bun --watch src/main.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["mcp", "ai", "model-context-protocol", "pexels", "api", "bun", "image"],
  "author": "",
  "license": "ISC",
  "engines": {
    "bun": ">=1.3.12"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.11.0",
    "fast-png": "^8.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.0"
  }
}
