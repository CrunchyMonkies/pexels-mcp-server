{
  "compilerOptions": {
    /* Bun runs TypeScript directly — type-check only, no emit. */
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    /* Strictness */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    /* Interop */
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "skipLibCheck": true,

    /* Bun globals (Bun.Image, Bun.write, node:* types) */
    "types": ["bun"]
  },
  "include": ["src"]
}
